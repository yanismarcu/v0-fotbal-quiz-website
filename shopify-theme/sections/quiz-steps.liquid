<section class="quiz-steps">
  <div class="quiz-container">
    <h2 class="quiz-section-title">{{ section.settings.heading }}</h2>
    <div class="quiz-steps__row">
      <div class="quiz-step">
        <div class="quiz-step__num">1</div>
        <h3 class="quiz-step__title">Înscriere</h3>
        <p class="quiz-step__text">Completezi datele și plătești taxa de participare.</p>
      </div>
      <div class="quiz-step">
        <div class="quiz-step__num">2</div>
        <h3 class="quiz-step__title">Acces competiție</h3>
        <p class="quiz-step__text">Primești acces la quiz în ziua concursului.</p>
      </div>
      <div class="quiz-step">
        <div class="quiz-step__num">3</div>
        <h3 class="quiz-step__title">Răspunzi la întrebări</h3>
        <p class="quiz-step__text">20 de întrebări în 15 minute.</p>
      </div>
      <div class="quiz-step">
        <div class="quiz-step__num">4</div>
        <h3 class="quiz-step__title">Clasament</h3>
        <p class="quiz-step__text">Scorul este calculat automat.</p>
      </div>
      <div class="quiz-step">
        <div class="quiz-step__num">5</div>
        <h3 class="quiz-step__title">Câștigi premii</h3>
        <p class="quiz-step__text">Top 3 primesc bani reali 💸</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quiz – Pași",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Cum funcționează?"
    }
  ],
  "presets": [{ "name": "Quiz – Pași" }]
}
{% endschema %}
