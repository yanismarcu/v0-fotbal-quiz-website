# Stripe Dashboard → Developers → API keys
# Test: sk_test_... | Producție: sk_live_... (niciodată în repo sau în chat)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# Developers → Webhooks → endpoint → „Signing secret” (whsec_...)
# Test și Live au secrete diferite — câte unul pe mediu.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# URL public al site-ului (producție). Folosit la success/cancel Checkout dacă lipsește antetul Origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Test local webhook: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# (CLI îți afișează un whsec de test pentru .env.local)
